<?xml version="1.0" encoding="utf-8"?>
<layout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        tools:context=".fragment.DefaultSettingFragment">

    <data>
        <variable
                name="viewModel"
                type="com.hhp227.knu_minigroup.viewmodel.DefaultSettingViewModel" />

        <variable
                name="handler"
                type="com.hhp227.knu_minigroup.handler.OnFragmentDefaultSettingEventListener" />
    </data>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0"
                android:background="@android:color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="5dp">

            <EditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginRight="5dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="그룹이름 입력"
                    android:inputType="textNoSuggestions"
                    android:paddingLeft="5dp"
                    android:text="@={viewModel.title}"
                    android:textAppearance="?android:attr/textAppearanceMedium">
                <requestFocus/>
            </EditText>

            <ImageView
                    android:id="@+id/iv_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:padding="5dp"
                    android:onClick="@{() -> viewModel.setTitle(``)}"
                    android:src="@{viewModel.title.empty ? @drawable/ic_clear_gray_24dp : @drawable/ic_clear_black_24dp}"
                    android:textColor="@android:color/darker_gray"
                    android:textStyle="bold"
                    tools:src="@drawable/ic_clear_gray_24dp" />

        </LinearLayout>

        <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <ImageView
                    android:id="@+id/iv_group_image"
                    android:layout_width="wrap_content"
                    android:layout_height="275dp"
                    android:layout_centerInParent="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/add_photo"
                    android:onClick="@{handler::onImageClick}"
                    app:imageUrl="@{viewModel.groupImage}" />

        </RelativeLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

            <EditText
                    android:padding="10dp"
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentRight="true"
                    android:gravity="top"
                    android:background="@null"
                    android:hint="그룹 설명을 입력하세요."
                    android:divider="@null"
                    android:text="@={viewModel.description}" />

            <RadioGroup
                    android:id="@+id/rg_jointype"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:gravity="bottom">

                <TextView
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="가입방식">

                </TextView>

                <RadioButton
                        android:layout_weight="2"
                        android:text="자동 승인"
                        android:id="@+id/rb_auto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:checked="@={viewModel.joinType}" />

                <RadioButton
                        android:layout_weight="2"
                        android:text="승인 확인"
                        android:id="@+id/rb_check"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />

            </RadioGroup>

        </LinearLayout>

    </LinearLayout>

</layout>
